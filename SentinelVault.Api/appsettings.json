{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=.;Database=SentinelVaultDb;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Storage": {
    "UploadPath": "LocalVault"
  },
  "Jwt": {
    "SecretKey": "your-super-secret-key-change-this-in-production-minimum-32-characters",
    "Issuer": "SentinelVault.Api",
    "Audience": "SentinelVault.Client",
    "ExpirationMinutes": 60
  }
}

